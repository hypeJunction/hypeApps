{
    "name": "hypejunction/hypeapps",
    "version": "4.0.0",
    "type": "elgg-plugin",
    "description": "hypeJunction plugin bootstrap",
    "homepage": "http://hypejunction.com",
    "keywords": [
        "elgg",
        "plugin",
        "hypeJunction",
        "bootstrap"
    ],
    "license": "GPL-2.0",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "info@hypejunction.com"
        }
    ],
    "extra": {
        "installer-name": "hypeapps",
        "elgg-plugin": {
            "id": "hypeapps"
        }
    },
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0",
        "smottt/wideimage": "~1.1.1",
        "elgg/elgg": "^4.0"
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        },
        "classmap": [
            "vendors/de77/"
        ]
    },
    "autoload-dev": {
        "psr-0": {
            "": "tests/phpunit/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
