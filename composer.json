{
	"name": "hypejunction/hypeapps",
	"version": "5.1.1",
	"type": "elgg-plugin",
	"description": "hypeJunction plugin bootstrap",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg",
		"plugin",
		"hypeJunction",
		"bootstrap"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"extra": {
		"installer-name": "hypeApps"
	},
	"require": {
		"composer/installers": "^1.0 || ^2.0",
		"php": ">=7.2",
		"elgg/elgg": "^3.0",
		"smottt/wideimage": "~1.1.1"
	},
	"autoload": {
		"psr-0": {
			"": "classes/"
		},
		"classmap": [
			"vendors/de77/"
		]
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload-dev": {
		"psr-4": {
			"hypeJunction\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
